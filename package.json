{
  "name": "devtools-unlock",
  "version": "1.0.0",
  "description": "Unlock DevTools on sites that block debugging (e.g. disable-devtool).",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/webLiang/devtools-unlock"
  },
  "scripts": {
    "zip": "bash scripts/pack.sh",
    "build:zip": "bash scripts/pack.sh",
    "release:github:dry": "node scripts/github-release.mjs --dry-run",
    "release:github": "node scripts/github-release.mjs --publish --commit --push",
    "release:github:full": "node scripts/github-release.mjs --full"
  },
  "keywords": [
    "chrome-extension",
    "devtools",
    "anti-debug"
  ],
  "author": "mengxianliang",
  "license": "ISC",
  "packageManager": "pnpm@10.34.3"
}
